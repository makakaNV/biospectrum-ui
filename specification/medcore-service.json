              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponseTestResponseDTO"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Tests"
        ],
        "summary": "Delete test by id",
        "description": "depending on the softDelete parameter either deletes test from the system or marks it as deleted",
        "operationId": "deleteTest",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "softDelete",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
