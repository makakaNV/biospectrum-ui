  "components": {
    "schemas": {
      "TestUpdateRequestDTO": {
        "type": "object",
        "properties": {
          "refValues": {
            "type": "string",
            "maxLength": 700,
            "minLength": 0
          }
        }
      },
      "MedCoreResponseTestResponseDTO": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/TestResponseDTO"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "OrderSimplifiedDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "patientId": {
            "type": "integer",
            "format": "int64"
          },
          "analysesIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "REGISTERED",
              "APPROVED",
              "PATCHING",
              "IN_PROGRESS",
              "COMPLETED",
              "CANCELED"
            ]
          }
        }
      },
      "TestResponseDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "order": {
            "$ref": "#/components/schemas/OrderSimplifiedDTO"
          },
          "result": {
            "type": "string"
          },
          "refValues": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "COMPLETED"
            ]
          },
          "finishedAt": {
            "type": "integer",
            "format": "int64"
          },
          "createdAt": {
            "type": "integer",
            "format": "int64"
          },
          "updatedAt": {
            "type": "integer",
            "format": "int64"
          },
          "deleted": {
            "type": "boolean"
          }
        }
      },
      "TestCompleteRequestDTO": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "result"
        ]
      },
      "MedCoreResponseOrderResponseDTO": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/OrderResponseDTO"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "OrderResponseDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "patientId": {
            "type": "integer",
            "format": "int64"
          },
          "analysesIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "REGISTERED",
              "APPROVED",
              "PATCHING",
              "IN_PROGRESS",
              "COMPLETED",
              "CANCELED"
            ]
          },
          "comment": {
            "type": "string"
          },
          "createdAt": {
            "type": "integer",
            "format": "int64"
          },
          "updatedAt": {
            "type": "integer",
            "format": "int64"
          },
          "createdBy": {
            "type": "string"
          },
          "deleted": {
            "type": "boolean"
          }
        }
      },
      "TestRegisterRequestDTO": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "integer",
            "format": "int64"
          },
          "refValues": {
            "type": "string",
            "maxLength": 700,
            "minLength": 0
          }
        },
        "required": [
          "orderId"
        ]
      },
      "TestInstantCreateRequestDTO": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "integer",
            "format": "int64"
          },
          "result": {
            "type": "string",
            "maxLength": 255,
            "minLength": 0
          },
          "refValues": {
            "type": "string",
            "maxLength": 700,
            "minLength": 0
          }
        },
        "required": [
          "orderId",
          "result"
        ]
      },
      "OrderCreateRequestDTO": {
        "type": "object",
        "properties": {
          "patientId": {
            "type": "integer",
            "format": "int64"
          },
          "analysesIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "minItems": 1
          },
          "comment": {
            "type": "string",
            "maxLength": 1000,
            "minLength": 5
          }
        },
        "required": [
          "analysesIds",
          "patientId"
        ]
      },
      "OrderUpdateAnalysesRequestDTO": {
        "type": "object",
        "properties": {
          "analysesIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "minItems": 1
          }
        },
        "required": [
          "analysesIds"
        ]
      },
      "MedCoreResponsePaginationResponseTestResponseDTO": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/PaginationResponseTestResponseDTO"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "format": "int64"
          },
          "limit": {
            "type": "integer",
            "format": "int32"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "pages": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "PaginationResponseTestResponseDTO": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TestResponseDTO"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "MedCoreResponsePaginationResponseOrderResponseDTO": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/PaginationResponseOrderResponseDTO"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "PaginationResponseOrderResponseDTO": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
