            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponseTestResponseDTO"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Tests"
        ],
        "summary": "Update test by id",
        "description": "updates test by its id",
        "operationId": "updateTest",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
