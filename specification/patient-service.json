{
  "openapi": "3.1.0",
  "info": {
    "title": "Patient service",
    "description": "patient restapi service for medstorm project",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://62.113.42.116:8100",
      "description": "Gateway server"
    },
    {
      "url": "http://62.113.42.116:8182",
      "description": "Patient service server"
    }
  ],
  "security": [
    {
      "Authorization": []
    }
  ],
  "tags": [
    {
      "name": "Patients",
      "description": "Patients methods"
    }
  ],
  "paths": {
    "/patients/{id}": {
      "get": {
        "tags": [
          "Patients"
        ],
        "summary": "Get patient by id",
        "description": "returns patient by his id",
        "operationId": "getPatientById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponsePatientResponseDTO"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Patients"
        ],
        "summary": "Update patient by id",
        "description": "updates patient by his id",
        "operationId": "updatePatient",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientUpdateRequestDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponsePatientResponseDTO"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Patients"
        ],
        "summary": "Delete patient by id",
        "description": "depending on the softDelete parameter either deletes patient from the system or marks it as deleted",
        "operationId": "deletePatient",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "softDelete",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponsePatientResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/patients/search": {
      "post": {
        "tags": [
          "Patients"
        ],
        "summary": "Search patients",
        "description": "Searches/sorts patients by predicates and sort field",
        "operationId": "searchPatients",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientSearchRequestDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponsePaginationResponsePatientResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/patients/create": {
      "post": {
        "tags": [
          "Patients"
        ],
        "summary": "Create new patient",
        "description": "saves new patient to the system",
        "operationId": "createPatient",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientCreateRequestDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponsePatientResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/patients/my": {
      "get": {
        "tags": [
          "Patients"
        ],
        "summary": "Get all patients assigned to account",
        "description": "returns a paginated list of all patients assigned to account sending the request",
        "operationId": "getAllPatientsByAccount",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 15
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponsePaginationResponsePatientResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/patients/all": {
      "get": {
        "tags": [
          "Patients"
        ],
        "summary": "Get all patients",
        "description": "returns a paginated list of all patients",
        "operationId": "getAllPatients",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 15
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponsePaginationResponsePatientResponseDTO"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PatientUpdateRequestDTO": {
        "type": "object",
        "properties": {
          "lastName": {
            "type": "string",
            "maxLength": 170,
            "minLength": 1
          },
          "firstName": {
            "type": "string",
            "maxLength": 170,
            "minLength": 1
          },
          "middleName": {
            "type": "string",
            "maxLength": 170,
            "minLength": 0
          },
          "birthDate": {
            "type": "integer",
            "format": "int64"
          },
          "gender": {
            "type": "string",
            "enum": [
              "MALE",
              "FEMALE"
            ]
          },
          "phoneNumber": {
            "type": "string"
          },
          "snils": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "maxLength": 150,
            "minLength": 0
          }
        },
        "required": [
          "birthDate",
          "firstName",
          "gender",
          "lastName",
          "snils"
        ]
      },
      "MedCoreResponsePatientResponseDTO": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/PatientResponseDTO"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "PatientResponseDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "lastName": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "middleName": {
            "type": "string"
          },
          "birthDate": {
            "type": "integer",
            "format": "int64"
          },
          "gender": {
            "type": "string",
            "enum": [
              "MALE",
              "FEMALE"
            ]
          },
          "phoneNumber": {
            "type": "string"
          },
          "snils": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "createdBy": {
            "type": "string"
          },
          "createdAt": {
            "type": "integer",
            "format": "int64"
          },
          "updatedAt": {
            "type": "integer",
            "format": "int64"
          },
          "deleted": {
            "type": "boolean"
          }
        }
      },
      "PatientSearchRequestDTO": {
        "type": "object",
        "properties": {
          "lastName": {
            "type": "string",
            "description": "Match in last name",
            "examples": [
              "Kuznetsov",
              "ov"
            ]
          },
          "firstName": {
            "type": "string",
            "description": "Match in first name",
            "examples": [
              "Sergey",
              "ser"
            ]
          },
          "middleName": {
            "type": "string",
            "description": "Match in middle name",
            "examples": [
              "Sergeevich",
              "ich"
            ]
          },
          "birthDate": {
            "type": "integer",
            "format": "int64",
            "description": "Filter on exact birth date",
            "example": "1990-01-02"
          },
          "gender": {
            "type": "string",
            "description": "Filter on gender",
            "enum": [
              "MALE",
              "FEMALE"
            ],
            "example": "MALE/FEMALE"
          },
          "phoneNumber": {
            "type": "string",
            "description": "Search patient with match in phone number",
            "examples": [
              "9028",
              "+7"
            ]
          },
          "snils": {
            "type": "string",
            "description": "Search patient with exact snils"
          },
          "email": {
            "type": "string",
            "description": "Search patient with match in email",
            "example": "@gmail"
          },
          "deleted": {
            "type": "boolean",
            "description": "Filter on soft deleted records",
            "example": true
          },
          "keyword": {
            "type": "string",
            "description": "Keyword matches in last/first/middle names & email",
            "example": "ivano"
          },
          "sortField": {
            "type": "string",
            "description": "Sorting by one of values. ID is default",
            "enum": [
              "LAST_NAME",
              "BIRTH_DATE",
              "SNILS",
              "EMAIL"
            ],
            "example": "LAST_NAME"
          }
        }
      },
      "MedCoreResponsePaginationResponsePatientResponseDTO": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/PaginationResponsePatientResponseDTO"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "format": "int64"
          },
          "limit": {
            "type": "integer",
            "format": "int32"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "pages": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "PaginationResponsePatientResponseDTO": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PatientResponseDTO"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "PatientCreateRequestDTO": {
        "type": "object",
        "description": "DTO для создания нового пациента",
        "properties": {
          "lastName": {
            "type": "string",
            "maxLength": 170,
            "minLength": 1
          },
          "firstName": {
            "type": "string",
            "maxLength": 170,
            "minLength": 1
          },
          "middleName": {
            "type": "string",
            "maxLength": 170,
            "minLength": 0
          },
          "birthDate": {
            "type": "integer",
            "format": "int64"
          },
          "gender": {
            "type": "string",
            "description": "Пол пациента",
            "enum": [
              "MALE",
              "FEMALE"
            ]
          },
          "phoneNumber": {
            "type": "string"
          },
          "snils": {
            "type": "string",
            "description": "Номер СНИЛС в формате 11 цифр",
            "example": 12345678900,
            "minLength": 1
          },
          "email": {
            "type": "string",
            "maxLength": 150,
            "minLength": 0
          }
        },
        "required": [
          "birthDate",
          "firstName",
          "gender",
          "lastName",
          "snils"
        ]
      }
    },
    "securitySchemes": {
      "Authorization": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}