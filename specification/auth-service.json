{
  "openapi": "3.1.0",
  "info": {
    "title": "Auth service",
    "description": "Auth restapi service for medstorm project",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "http://62.113.42.116:8100",
      "description": "Gateway server"
    },
    {
      "url": "http://62.113.42.116:8190",
      "description": "Auth service server"
    }
  ],
  "security": [
    {
      "Authorization": []
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "Users methods"
    },
    {
      "name": "Auth",
      "description": "Authorization methods"
    }
  ],
  "paths": {
    "/users/{id}": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get user by id",
        "description": "returns user by his id",
        "operationId": "getUserById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponseUserResponseDTO"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Users"
        ],
        "summary": "Update user by id",
        "description": "updates user by his id",
        "operationId": "updateUser",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserUpdateRequestDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponseUserResponseDTO"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Users"
        ],
        "summary": "Delete user by id",
        "description": "depending on the softDelete parameter either deletes user from the system or marks it as deleted",
        "operationId": "deleteUser",
        "parameters": [
          {
            "name": "softDelete",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponseUserResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Create new user",
        "description": "saves new user to the system",
        "operationId": "createUser",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreateRequestDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponseUserResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/users/search": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Search users",
        "description": "Searches/sorts users by predicates and sort field",
        "operationId": "searchUsers",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 15
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserSearchRequestDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponsePaginationResponseUserResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register user",
        "description": "Saves user, returns access/refresh tokens",
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegistrationDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Returns user profile with tokens & roles",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login user",
        "description": "Authenticate user credentials",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Returns user profile with tokens & roles",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/users/me": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get my user info",
        "description": "Returns user info by jwt token that provided in request",
        "operationId": "getMyInfo",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponseUserResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/users/all": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get all users",
        "description": "returns a paginated list of all users",
        "operationId": "getAllUsers",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 15
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MedCoreResponsePaginationResponseUserResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/auth/refresh_token": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Refresh access token via refresh-token",
        "description": "Generates new both tokens",
        "operationId": "refreshToken",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns user profile with tokens & roles",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileResponseDTO"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserUpdateRequestDTO": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "maxLength": 45,
            "minLength": 2
          },
          "email": {
            "type": "string",
            "maxLength": 150,
            "minLength": 0
          }
        },
        "required": [
          "email",
          "username"
        ]
      },
      "MedCoreResponseUserResponseDTO": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/UserResponseDTO"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "RoleResponseDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "UserResponseDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "created": {
            "type": "integer",
            "format": "int64"
          },
          "lastLogin": {
            "type": "integer",
            "format": "int64"
          },
          "registrationStatus": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "INACTIVE",
              "PENDING_CONFIRMATION"
            ]
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoleResponseDTO"
            }
          }
        }
      },
      "UserCreateRequestDTO": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "maxLength": 45,
            "minLength": 2
          },
          "password": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "maxLength": 150,
            "minLength": 0
          }
        },
        "required": [
          "email",
          "password",
          "username"
        ]
      },
      "UserSearchRequestDTO": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "Match in username",
            "examples": [
              "medic",
              "admin"
            ]
          },
          "email": {
            "type": "string",
            "description": "Match in email",
            "examples": [
              "gmail",
              "medic2007"
            ]
          },
          "deleted": {
            "type": "boolean",
            "description": "Filter on soft deleted records",
            "example": true
          },
          "keyword": {
            "type": "string",
            "description": "Keyword matches in username & email",
            "example": "medic"
          },
          "sortField": {
            "type": "string",
            "description": "Sorting by one of values. ID is default",
            "enum": [
              "USERNAME",
              "EMAIL"
            ],
            "example": "USERNAME"
          }
        }
      },
      "MedCoreResponsePaginationResponseUserResponseDTO": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/PaginationResponseUserResponseDTO"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "format": "int64"
          },
          "limit": {
            "type": "integer",
            "format": "int32"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "pages": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "PaginationResponseUserResponseDTO": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserResponseDTO"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "UserRegistrationDTO": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 1
          },
          "confirmPassword": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "confirmPassword",
          "email",
          "password",
          "username"
        ]
      },
      "UserProfileResponseDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "registrationStatus": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "INACTIVE",
              "PENDING_CONFIRMATION"
            ]
          },
          "lastLogin": {
            "type": "integer",
            "format": "int64"
          },
          "token": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoleResponseDTO"
            }
          }
        }
      },
      "UserLoginDTO": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email",
            "example": "user@gmail.com"
          },
          "password": {
            "type": "string",
            "description": "User password",
            "example": "Test11111"
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    },
    "securitySchemes": {
      "Authorization": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}